#include "raylib.h"

int main()
{
    int posX = 0;

    InitWindow(800, 450, "Testando FPS");

    SetTargetFPS(30);

    while (!WindowShouldClose())
    {
        posX+=1;

        BeginDrawing();

        ClearBackground(RAYWHITE);

        DrawRectangle(posX, 100, 300, 100, BLUE);

        EndDrawing();
    }

    CloseWindow();

    return 0;
}
