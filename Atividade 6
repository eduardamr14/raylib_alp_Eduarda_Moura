#include "raylib.h"

int main()
{
    float posX = -100; 

    Texture2D sprite;

    InitWindow(800, 450, "Movimento Profissional");

    sprite = LoadTexture("feliz.png");

    while (!WindowShouldClose())
    {
        posX += GetFrameTime() * 600;

        if (posX > 800)
        {
            posX = -100;
        }

        BeginDrawing();

        ClearBackground(RAYWHITE);

        DrawTexture(sprite, posX, 10, WHITE);

        EndDrawing();
    }

    CloseWindow();

    return 0;
}
