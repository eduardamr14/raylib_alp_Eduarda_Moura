#include "raylib.h"

int main()
{
    InitWindow(800, 450, "meu primeiro game");

    while (!WindowShouldClose())
    {
        BeginDrawing();

        ClearBackground(RAYWHITE);

        
       DrawRectangle(100, 100, 100, 50, RED);
       DrawRectangle(200, 200, 100, 90, GREEN);
       DrawRectangle(300, 300, 100, 90, YELLOW);

        EndDrawing();
    }

    CloseWindow();

    return 0;
}
