#include "raylib.h"

int main()
{
    Texture2D sprite; 
    Texture2D sprite2;
    Texture2D sprite3;
   

    InitWindow(800, 450, "Meu Primeiro Personagem");

    sprite = LoadTexture("inimigo.png");  
    sprite2 = LoadTexture("luvaboxe.png"); 
    sprite3 = LoadTexture("feliz.png"); 
  

    while (!WindowShouldClose())
    {
        BeginDrawing();

        ClearBackground(RAYWHITE);

        DrawTexture(sprite, 250, 80, RED);
        DrawTexture(sprite2, 300, 100, GREEN);
        DrawTexture(sprite3, 450, 100, BLUE);
      

        EndDrawing();
    }

    CloseWindow();

    return 0;
}
